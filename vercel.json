{
    "framework": "vite",
    "functions": {
        "api/slack/weekly-summary.js": {
            "maxDuration": 120
        }
    },
    "rewrites": [
        { "source": "/entry/:id", "destination": "/index.html" },
        { "source": "/submit", "destination": "/index.html" },
        { "source": "/podcast-test", "destination": "/index.html" }
    ],
    "crons": [
        {
            "path": "/api/slack/daily-summary",
            "schedule": "0 14 * * *"
        },
        {
            "path": "/api/slack/weekly-summary",
            "schedule": "0 20 * * 5"
        }
    ]
}
