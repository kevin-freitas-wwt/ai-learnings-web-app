{
    "framework": "vite",
    "rewrites": [
        { "source": "/((?!api/).*)", "destination": "/index.html" }
    ],
    "crons": [
        {
            "path": "/api/slack/daily-summary",
            "schedule": "0 14 * * *"
        },
        {
            "path": "/api/slack/weekly-summary",
            "schedule": "0 20 * * 5"
        }
    ]
}
